# SalesBench secrets. Copy this file to `secrets.env` and fill in your keys.
# Then it's referenced by env_file in configs/lab/* and configs/curriculum/*.
#
# - OPENAI_API_KEY is REQUIRED — used by the buyer LLM (gpt-5-mini) during
#   every sales call. Without it, every offer auto-rejects and the agent
#   cannot learn.
# - PRIME_API_KEY is set automatically by `prime login`. You usually don't
#   need to add it here.
# - WANDB_API_KEY is optional; set it if you want training curves on W&B.

OPENAI_API_KEY=sk-...
# WANDB_API_KEY=...
